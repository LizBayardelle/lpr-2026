<% content_for :title, "Edit Draw" %>

<div class="container-wide" style="padding-top: 6rem;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <%= render "admin/breadcrumbs", crumbs: [
        { label: "Loans", path: admin_loans_path },
        { label: @loan.borrower_name, path: admin_loan_path(@loan, tab: "draws") },
        { label: "Edit Draw" }
      ] %>
    </div>
    <%= button_to "Delete Draw", admin_loan_loan_draw_path(@loan, @draw), method: :delete, class: "btn-filled btn-filled-danger", style: "font-size: 11px; padding: 6px 14px;", data: { confirm: "Are you sure you want to delete this draw?" } %>
  </div>

  <h1 class="heading-1">Edit Draw</h1>

  <div class="card" style="padding: 2rem; margin-top: 1.5rem;">
    <%= form_with model: [:admin, @loan, @draw], local: true do |f| %>
      <div class="field-row">
        <div class="field">
          <%= f.label :draw_date, "Draw Date" %>
          <%= f.date_field :draw_date, class: "field-input" %>
        </div>
        <div class="field">
          <%= f.label :amount, "Amount" %>
          <%= f.number_field :amount, step: 0.01, class: "field-input" %>
        </div>
      </div>

      <div class="field">
        <%= f.label :description, "Description" %>
        <%= f.text_field :description, class: "field-input" %>
      </div>

      <div class="field">
        <%= f.label :inspection_notes, "Inspection Notes" %>
        <%= f.text_area :inspection_notes, class: "field-input", rows: 3 %>
      </div>

      <div style="margin-top: 1.5rem;">
        <%= btn_filled_tag "Update Draw", nil, type: "submit" %>
      </div>
    <% end %>
  </div>

</div>
