<div class="container-narrow" style="padding-top: 6rem;">
  <%= render "admin/breadcrumbs", crumbs: [
    { label: "Blog Posts", path: admin_blogs_path },
    { label: "Edit" }
  ] %>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 class="heading-1">Edit Blog Post</h1>
    <%= button_to admin_blog_path(@blog), method: :delete,
        style: "background: none; border: none; color: var(--color-steel); cursor: pointer; font-size: 1.125rem; padding: 0.375rem; transition: color 0.15s;",
        title: "Delete Post",
        data: { turbo_confirm: "Are you sure you want to delete this post?" } do %>
      <i class="fa-solid fa-trash-can"></i>
    <% end %>
  </div>

  <div class="card">
    <%= render "form", blog: @blog, categories: @categories %>
</div>
