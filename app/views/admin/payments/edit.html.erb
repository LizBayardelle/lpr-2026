<% content_for :title, "Edit Payment" %>

<div class="container-wide" style="padding-top: 6rem;">
  <%= render "admin/breadcrumbs", crumbs: [
    { label: "Loans", path: admin_loans_path },
    { label: @loan.borrower_name, path: admin_loan_path(@loan, tab: "payments") },
    { label: "Edit Payment" }
  ] %>

  <h1 class="heading-1">Edit Payment</h1>

  <div class="card" style="padding: 2rem; margin-top: 1.5rem;">
    <%= render "form", loan: @loan, payment: @payment %>
  </div>

  <div style="margin-top: 2rem;">
    <%= button_to "Delete Payment", admin_loan_payment_path(@loan, @payment), method: :delete, class: "btn-filled btn-filled-danger", style: "font-size: 11px; padding: 6px 14px;", data: { turbo_confirm: "Are you sure you want to delete this payment?" } %>
  </div>
</div>
