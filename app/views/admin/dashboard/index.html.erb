<div class="container-wide" style="padding-top: 6rem;">
  <%= render "admin/breadcrumbs", crumbs: [{ label: "Dashboard" }] %>
  <h1 class="heading-1" style="color: var(--color-navy);">Dashboard</h1>

  <%# ──────────────────────────── MANAGE ──────────────────────────── %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: 1.5rem; margin-top: 2rem;">
    <a href="<%= admin_loans_path %>" class="admin-action-card" style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="10" y1="3" x2="10" y2="9"/></svg>
      </div>
      <div>
        <p class="heading-3">Loan Management</p>
        <p class="text-small" style="margin-top: 0.25rem;">Track loans, payments, and statements.</p>
      </div>
    </a>

    <a href="<%= admin_blogs_path %>" class="admin-action-card" style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </div>
      <div>
        <p class="heading-3">Blog Posts</p>
        <p class="text-small" style="margin-top: 0.25rem;">Create, edit, and publish articles.</p>
      </div>
    </a>

    <a href="<%= admin_client_uploads_path %>" class="admin-action-card" style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
      </div>
      <div>
        <p class="heading-3">Client Uploads</p>
        <p class="text-small" style="margin-top: 0.25rem;">
          Review and assign uploaded documents.
          <% if @pending_uploads_count > 0 %>
            <span class="badge badge-warning" style="margin-left: 0.25rem;"><%= @pending_uploads_count %> pending</span>
          <% end %>
        </p>
      </div>
    </a>

    <a href="<%= admin_contact_submissions_path %>" class="admin-action-card" style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div>
        <p class="heading-3">Messages</p>
        <p class="text-small" style="margin-top: 0.25rem;">
          Contact form submissions.
          <% if @unread_messages_count > 0 %>
            <span class="badge badge-warning" style="margin-left: 0.25rem;"><%= @unread_messages_count %> new</span>
          <% end %>
        </p>
      </div>
    </a>

    <a href="<%= admin_categories_path %>" class="admin-action-card" style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </div>
      <div>
        <p class="heading-3">Categories</p>
        <p class="text-small" style="margin-top: 0.25rem;">Organize posts by topic.</p>
      </div>
    </a>
  </div>

  <%# ──────────────────────────── STATS ──────────────────────────── %>
  <div class="stat-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem;">
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= @active_loans_count %></div>
      <div class="stat-label">Active Loans</div>
    </div>
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= number_to_currency(@total_portfolio) %></div>
      <div class="stat-label">Portfolio Value</div>
    </div>
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= @maturing_soon_count %></div>
      <div class="stat-label">Maturing (30d)</div>
    </div>
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= @published_count %></div>
      <div class="stat-label">Published Posts</div>
    </div>
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= @draft_count %></div>
      <div class="stat-label">Drafts</div>
    </div>
    <div class="card" style="padding: 1.5rem;">
      <div class="stat-value" style="color: var(--color-navy);"><%= @category_count %></div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  <%# ──────────────────────────── RECENT POSTS ──────────────────────────── %>
  <% if @recent_blogs.any? %>
    <div class="section">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <span class="section-label" style="margin-bottom: 0;">Recent Posts</span>
        <a href="<%= admin_blogs_path %>" style="font-size: 0.8125rem; color: var(--color-steel);">View all &rarr;</a>
      </div>

      <div class="card" style="padding: 0; margin-top: 1.5rem;">
        <div class="table-container" style="padding: 1rem 0 0;">
          <table class="data-table">
            <thead>
              <tr>
                <th style="padding-left: 2rem;">Title</th>
                <th>Status</th>
                <th>Date</th>
                <th style="padding-right: 2rem;"></th>
              </tr>
            </thead>
            <tbody>
              <% @recent_blogs.each do |blog| %>
                <tr>
                  <td style="font-weight: 600; padding-left: 2rem;"><%= blog.title %></td>
                  <td>
                    <% if blog.published? %>
                      <span class="badge badge-success">Published</span>
                    <% else %>
                      <span class="badge badge-neutral">Draft</span>
                    <% end %>
                  </td>
                  <td class="text-small"><%= blog.published_at&.strftime("%b %-d, %Y") || blog.created_at.strftime("%b %-d, %Y") %></td>
                  <td style="text-align: right; padding-right: 2rem;">
                    <a href="<%= edit_admin_blog_path(blog) %>" style="font-size: 0.8125rem;">Edit</a>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
