<% content_for :title, @user.display_name %>

<div class="container-wide" style="padding-top: 6rem;">
  <%= render "admin/breadcrumbs", crumbs: [
    { label: "Users", path: admin_users_path },
    { label: @user.display_name }
  ] %>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
      <h1 class="heading-1" style="color: var(--color-navy);"><%= @user.display_name %></h1>
      <p class="text-small" style="color: var(--color-steel); margin-top: 0.25rem;"><%= @user.email %></p>
    </div>
    <div style="display: flex; gap: 0.5rem;">
      <%= btn_tag "Edit", edit_admin_user_path(@user) %>
      <%= link_to "Resend Invite", resend_invite_admin_user_path(@user), data: { turbo_method: :post }, style: "font-size: 0.8125rem; color: var(--color-steel); padding: 0.5rem 1rem;" %>
      <%= link_to "Send Password Reset", send_reset_admin_user_path(@user), data: { turbo_method: :post, turbo_confirm: "Send a password reset email to #{@user.email}?" }, style: "font-size: 0.8125rem; color: var(--color-steel); padding: 0.5rem 1rem;" %>
    </div>
  </div>

  <%# ── User Details ── %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
    <div class="card" style="padding: 1.5rem;">
      <span class="section-label" style="margin-bottom: 1rem; display: block;">Profile</span>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <div class="text-small" style="color: var(--color-steel);">First Name</div>
          <div style="font-weight: 600;"><%= @user.first_name.presence || "-" %></div>
        </div>
        <div>
          <div class="text-small" style="color: var(--color-steel);">Last Name</div>
          <div style="font-weight: 600;"><%= @user.last_name.presence || "-" %></div>
        </div>
        <div>
          <div class="text-small" style="color: var(--color-steel);">Phone</div>
          <div style="font-weight: 600;"><%= @user.phone_number.presence || "-" %></div>
        </div>
        <div>
          <div class="text-small" style="color: var(--color-steel);">Member Since</div>
          <div style="font-weight: 600;"><%= @user.created_at.strftime("%b %-d, %Y") %></div>
        </div>
      </div>
      <% if @user.notes.present? %>
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
          <div class="text-small" style="color: var(--color-steel);">Notes</div>
          <div style="margin-top: 0.25rem;"><%= @user.notes %></div>
        </div>
      <% end %>
    </div>

    <div class="card" style="padding: 1.5rem;">
      <span class="section-label" style="margin-bottom: 1rem; display: block;">Permissions</span>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <div style="font-weight: 600;">Admin Access</div>
            <div class="text-small" style="color: var(--color-steel);">Can access admin dashboard and manage loans</div>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <% if @user.admin? %>
              <span class="badge badge-success">Enabled</span>
            <% else %>
              <span class="badge badge-neutral">Disabled</span>
            <% end %>
            <% if current_user.godpowers? && @user != current_user %>
              <%= link_to(@user.admin? ? "Revoke" : "Grant",
                    toggle_admin_admin_user_path(@user),
                    data: { turbo_method: :post, turbo_confirm: "#{@user.admin? ? 'Revoke' : 'Grant'} admin access for #{@user.display_name}?" },
                    style: "font-size: 0.8125rem;") %>
            <% end %>
          </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
          <div>
            <div style="font-weight: 600;">Godpowers</div>
            <div class="text-small" style="color: var(--color-steel);">Full system access including user permission management</div>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <% if @user.godpowers? %>
              <span class="badge badge-danger">Enabled</span>
            <% else %>
              <span class="badge badge-neutral">Disabled</span>
            <% end %>
            <% if current_user.godpowers? && @user != current_user %>
              <%= link_to(@user.godpowers? ? "Revoke" : "Grant",
                    toggle_godpowers_admin_user_path(@user),
                    data: { turbo_method: :post, turbo_confirm: "#{@user.godpowers? ? 'Revoke' : 'Grant'} godpowers for #{@user.display_name}?" },
                    style: "font-size: 0.8125rem;") %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Loan Roles ── %>
  <div class="section">
    <span class="section-label" style="margin-bottom: 1rem; display: block;">Loan Assignments</span>

    <%# Add loan role form %>
    <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
      <%= form_tag add_loan_role_admin_user_path(@user), method: :post, style: "display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;" do %>
        <div style="flex: 1; min-width: 12rem;">
          <label class="text-small" style="display: block; margin-bottom: 0.25rem; color: var(--color-steel);">Loan</label>
          <select name="loan_id" class="field-input" style="width: 100%;" required>
            <option value="">Select a loan...</option>
            <% @available_loans.each do |loan| %>
              <option value="<%= loan.id %>"><%= loan.borrower_name %> - <%= loan.property_address %></option>
            <% end %>
          </select>
        </div>
        <div style="min-width: 10rem;">
          <label class="text-small" style="display: block; margin-bottom: 0.25rem; color: var(--color-steel);">Role</label>
          <select name="role" class="field-input" style="width: 100%;" required>
            <option value="">Select role...</option>
            <% LoanRole::ROLES.each do |role| %>
              <option value="<%= role %>"><%= role.titleize.gsub("_", " ") %></option>
            <% end %>
          </select>
        </div>
        <div>
          <%= btn_tag "Add Role" %>
        </div>
      <% end %>
    </div>

    <%# Existing loan roles table %>
    <% if @loan_roles.any? %>
      <div class="card" style="padding: 0;">
        <div class="table-container" style="padding: 1rem 0 0;">
          <table class="data-table">
            <thead>
              <tr>
                <th style="padding-left: 2rem;">Loan</th>
                <th>Property</th>
                <th>Role</th>
                <th>Status</th>
                <th style="padding-right: 2rem;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @loan_roles.each do |lr| %>
                <tr>
                  <td style="padding-left: 2rem;">
                    <%= link_to lr.loan.borrower_name, admin_loan_path(lr.loan), style: "font-weight: 600;" %>
                  </td>
                  <td class="text-small"><%= lr.loan.property_address %></td>
                  <td><span class="badge badge-navy"><%= lr.role_label %></span></td>
                  <td>
                    <% status_color = case lr.loan.status
                       when "active" then "success"
                       when "paid_off" then "neutral"
                       when "default", "foreclosure" then "danger"
                       when "extended" then "warning"
                       else "neutral"
                       end %>
                    <span class="badge badge-<%= status_color %>"><%= lr.loan.status.titleize %></span>
                  </td>
                  <td style="padding-right: 2rem;">
                    <%= link_to "Remove",
                          remove_loan_role_admin_user_path(@user, loan_role_id: lr.id),
                          data: { turbo_method: :delete, turbo_confirm: "Remove #{lr.role_label} role from this loan?" },
                          style: "font-size: 0.8125rem; color: var(--color-danger);" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="card" style="text-align: center; padding: 3rem;">
        <p style="color: var(--color-steel);">No loan assignments yet.</p>
      </div>
    <% end %>
  </div>
</div>
