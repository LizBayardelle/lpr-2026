<div class="container-wide" style="padding-top: 6rem;">
  <%= render "admin/breadcrumbs", crumbs: [{ label: "Documents" }] %>

  <div style="display: flex; justify-content: space-between; align-items: center;">
    <h1 class="heading-1" style="color: var(--color-navy);">Client Uploads</h1>
    <% if @pending_count > 0 %>
      <span class="badge badge-warning"><%= @pending_count %> pending</span>
    <% end %>
  </div>

  <%# ── Status Tabs ── %>
  <div style="display: flex; gap: 0.5rem; margin-top: 1.5rem; border-bottom: 2px solid #e5e7eb; padding-bottom: 0;">
    <% [["pending", "Pending"], ["assigned", "Assigned"], ["rejected", "Rejected"]].each do |value, label| %>
      <a href="<%= admin_client_uploads_path(status: value) %>"
         style="padding: 0.5rem 1rem; font-size: 0.8125rem; font-weight: 600; text-decoration: none;
                border-bottom: 2px solid <%= @status == value ? 'var(--color-navy)' : 'transparent' %>;
                color: <%= @status == value ? 'var(--color-navy)' : 'var(--color-steel)' %>;
                margin-bottom: -2px;">
        <%= label %>
      </a>
    <% end %>
  </div>

  <%# ── Table ── %>
  <% if @uploads.any? %>
    <div class="card" style="padding: 0; margin-top: 1.5rem;">
      <div class="table-container" style="padding: 1rem 0 0; overflow-x: auto; -webkit-overflow-scrolling: touch;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="padding-left: 2rem;">Client</th>
              <th>Document</th>
              <th>Type</th>
              <th>Uploaded</th>
              <th style="padding-right: 2rem;"></th>
            </tr>
          </thead>
          <tbody>
            <% @uploads.each do |upload| %>
              <tr>
                <td style="padding-left: 2rem;">
                  <div style="font-weight: 600;"><%= upload.client_name %></div>
                  <div class="text-small" style="color: var(--color-steel);"><%= upload.client_email %></div>
                  <% if upload.client_phone.present? %>
                    <div class="text-small" style="color: var(--color-steel);"><%= upload.client_phone %></div>
                  <% end %>
                </td>
                <td>
                  <% if upload.file.attached? %>
                    <%= link_to (upload.name.presence || upload.file.filename), rails_blob_path(upload.file, disposition: "inline"), target: "_blank", style: "font-weight: 500;" %>
                  <% else %>
                    <span style="color: var(--color-steel);">No file</span>
                  <% end %>
                  <% if upload.description.present? %>
                    <div class="text-small" style="color: var(--color-steel); margin-top: 0.25rem;"><%= truncate(upload.description, length: 80) %></div>
                  <% end %>
                </td>
                <td>
                  <span class="badge badge-navy" style="white-space: nowrap;"><%= upload.document_type_label %></span>
                </td>
                <td class="text-small">
                  <%= upload.created_at.strftime("%b %-d, %Y") %>
                  <div style="color: var(--color-steel);"><%= upload.created_at.strftime("%-I:%M %p") %></div>
                </td>
                <td style="padding-right: 2rem; text-align: right; white-space: nowrap;">
                  <% if upload.pending? %>
                    <%# ── Assign form ── %>
                    <%= form_with url: assign_admin_client_upload_path(upload), method: :post, style: "display: inline-flex; gap: 0.5rem; align-items: center;" do |f| %>
                      <%= f.select :loan_id, @loans.map { |l| ["#{l.borrower_name} — #{l.property_address}", l.id] },
                          { include_blank: "Assign to loan..." },
                          class: "field-input", style: "font-size: 0.75rem; padding: 0.375rem 0.5rem; width: auto; max-width: 14rem;" %>
                      <%= f.submit "Assign", class: "btn-filled", style: "font-size: 0.75rem; padding: 0.375rem 0.75rem;" %>
                    <% end %>
                    <%= button_to "Reject", reject_admin_client_upload_path(upload), method: :post,
                        class: "btn-filled btn-filled-ghost",
                        style: "font-size: 0.75rem; padding: 0.375rem 0.75rem; color: var(--color-maroon); display: inline;",
                        data: { turbo_confirm: "Reject this upload?" } %>
                  <% elsif upload.assigned? %>
                    <span class="badge badge-success">Assigned</span>
                    <% if upload.loan %>
                      <div class="text-small" style="margin-top: 0.25rem;">
                        <%= link_to upload.loan.borrower_name, admin_loan_path(upload.loan) %>
                      </div>
                    <% end %>
                  <% elsif upload.rejected? %>
                    <span class="badge badge-danger">Rejected</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card" style="margin-top: 1.5rem; text-align: center; padding: 3rem;">
      <p style="color: var(--color-steel);">No <%= @status %> uploads.</p>
    </div>
  <% end %>
</div>
