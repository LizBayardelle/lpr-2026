<% content_for :title, "Statement — #{@statement.period_start.strftime('%b %-d')} – #{@statement.period_end.strftime('%b %-d, %Y')}" %>

<div class="container-wide" style="padding-top: 6rem; padding-bottom: 6rem;">
  <div class="admin-breadcrumbs-inline" style="display: flex; justify-content: space-between; align-items: center;">
    <%= render "admin/breadcrumbs", crumbs: [
      { label: "Loans", path: admin_loans_path },
      { label: @loan.borrower_name, path: admin_loan_path(@loan, tab: "statements") },
      { label: "#{@statement.period_start.strftime('%b %Y')} Statement" }
    ] %>
    <div style="display: flex; align-items: center; gap: 1.25rem;">
      <%= link_to admin_loan_loan_statement_path(@loan, @statement, format: :pdf), target: "_blank", style: "display: inline-flex; align-items: center; gap: 0.375rem; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-navy); text-decoration: none;" do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
        Download PDF
      <% end %>
      <% if @statement.stale? %>
        <span style="font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-steel);">Regenerate before sending</span>
      <% else %>
        <%= btn_filled_tag "Send Statement", "#", data: { modal_target: "send-statement-modal" }, style: "font-size: 11px; padding: 6px 14px;" %>
      <% end %>
    </div>
  </div>

  <% if @statement.stale? %>
    <div class="flash-alert" style="margin-bottom: 1.5rem;">
      This statement may be out of date. Activity in this period has changed since it was generated. Consider regenerating.
    </div>
  <% end %>

  <%# ── Navy Header ── %>
  <div class="card-navy ctx-navy" style="padding: 2rem 2.5rem; margin-bottom: 2rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;">
    <div>
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
        <h1 style="font-family: 'Barlow Condensed', sans-serif; font-size: 1.75rem; font-weight: 700; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; margin: 0;">
          Account Statement
        </h1>
        <% if @statement.stale? %>
          <span class="badge badge-warning">Stale</span>
        <% end %>
      </div>
      <div style="font-weight: 600; font-size: 1.0625rem; color: #fff;"><%= @loan.borrower_name %></div>
      <% if @loan.borrower_address.present? %>
        <div style="font-size: 0.8125rem; color: var(--color-concrete); white-space: pre-line; margin-top: 0.125rem; line-height: 1.5;"><%= @loan.borrower_address %></div>
      <% end %>
      <div style="font-size: 0.8125rem; color: var(--color-concrete); margin-top: 0.25rem;"><%= @loan.property_address %></div>
      <% if @loan.loan_number.present? %>
        <div style="font-size: 0.8125rem; color: var(--color-concrete); margin-top: 0.25rem;">Loan <%= @loan.loan_number %></div>
      <% end %>
    </div>
    <div style="text-align: right;">
      <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-concrete); margin-bottom: 0.375rem;">Period</div>
      <div style="font-size: 1.0625rem; font-weight: 600; color: #fff; white-space: nowrap;"><%= @statement.period_start.strftime("%b %-d") %> &ndash; <%= @statement.period_end.strftime("%b %-d, %Y") %></div>
      <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-concrete); margin-top: 1rem; margin-bottom: 0.375rem;">Generated</div>
      <div style="font-size: 0.8125rem; color: var(--color-concrete);"><%= @statement.created_at.strftime("%b %-d, %Y at %-I:%M %p") %></div>
    </div>
  </div>

  <%# ── Loan Details + Balances + Charges — 3-column row ── %>
  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

    <%# Loan Details %>
    <div class="card" style="padding: 1.75rem 2rem;">
      <h3 class="heading-3" style="margin-bottom: 1.25rem;">Loan Details</h3>
      <table style="width: 100%; font-size: 0.8125rem;">
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Principal</td>
          <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= number_to_currency(@loan.loan_amount) %></td>
        </tr>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Interest Rate</td>
          <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= @loan.effective_interest_rate %>%</td>
        </tr>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Calculated</td>
          <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= @loan.interest_calc_method.gsub("_", "/").gsub(/[a-z]+/) { |w| w.capitalize } %></td>
        </tr>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Origination</td>
          <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= @loan.origination_date.strftime("%b %-d, %Y") %></td>
        </tr>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Payment Type</td>
          <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= @loan.payment_type.titleize %></td>
        </tr>
        <% if @loan.split_payment? %>
          <tr>
            <td style="padding: 0.375rem 0; color: var(--color-steel);">Cash Payment</td>
            <td style="padding: 0.375rem 0; text-align: right; font-weight: 500;"><%= number_to_currency(@loan.monthly_cash_payment) %> / mo</td>
          </tr>
        <% end %>
      </table>
    </div>

    <%# Period Summary %>
    <div class="card" style="padding: 1.75rem 2rem;">
      <h3 class="heading-3" style="margin-bottom: 1.25rem;">Period Summary</h3>
      <table style="width: 100%; font-size: 0.8125rem;">
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Beginning Balance</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;"><%= number_to_currency(@statement.beginning_balance) %></td>
        </tr>
        <% if @period_draws.any? %>
          <tr>
            <td style="padding: 0.375rem 0; color: var(--color-steel);">Draws Funded</td>
            <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;">+ <%= number_to_currency(@period_draws.sum(:amount)) %></td>
          </tr>
        <% end %>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Interest Charged</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;"><%= number_to_currency(@statement.interest_due) %></td>
        </tr>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Interest Paid</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;">(<%= number_to_currency(@period_payments.sum(:interest_amount)) %>)</td>
        </tr>
        <% if @loan.split_payment? %>
          <% cash_payments = @period_payments.where(loan_reserve_id: nil) %>
          <% reserve_payments = @period_payments.where.not(loan_reserve_id: nil) %>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Cash</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);">(<%= number_to_currency(cash_payments.sum(:interest_amount)) %>)</td>
          </tr>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Reserve</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);">(<%= number_to_currency(reserve_payments.sum(:interest_amount)) %>)</td>
          </tr>
        <% end %>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Principal Paid</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;">(<%= number_to_currency(@period_payments.sum(:principal_amount)) %>)</td>
        </tr>
        <tr style="border-top: 2px solid #000;">
          <td style="padding: 0.625rem 0 0; font-weight: 600;">Ending Balance</td>
          <td class="text-money" style="padding: 0.625rem 0 0; font-weight: 600; font-size: inherit;"><%= number_to_currency(@statement.ending_balance) %></td>
        </tr>
      </table>
    </div>

    <%# Amount Due %>
    <div class="card" style="padding: 1.75rem 2rem;">
      <h3 class="heading-3" style="margin-bottom: 1.25rem;">Amount Due</h3>
      <table style="width: 100%; font-size: 0.8125rem;">
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Total Due</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;"><%= number_to_currency(@statement.total_due) %></td>
        </tr>
        <tr>
          <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Interest</td>
          <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);"><%= number_to_currency(@statement.interest_due) %></td>
        </tr>
        <% if @loan.split_payment? %>
          <tr>
            <td style="padding: 0.125rem 0 0.125rem 1.75rem; color: var(--color-concrete); font-size: 0.75rem;"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Cash</td>
            <td class="text-money" style="padding: 0.125rem 0; font-size: 0.75rem; color: var(--color-concrete);"><%= number_to_currency(@loan.monthly_cash_payment) %></td>
          </tr>
          <tr>
            <td style="padding: 0.125rem 0 0.125rem 1.75rem; color: var(--color-concrete); font-size: 0.75rem;"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Reserve</td>
            <td class="text-money" style="padding: 0.125rem 0; font-size: 0.75rem; color: var(--color-concrete);"><%= number_to_currency(@loan.reserve_payment_amount) %></td>
          </tr>
        <% end %>
        <% if @statement.principal_due > 0 %>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Principal</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);"><%= number_to_currency(@statement.principal_due) %></td>
          </tr>
        <% end %>
        <% if @statement.late_fee > 0 %>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-maroon);"><span style="color: var(--color-maroon); margin-right: 0.375rem;">&#x2514;</span> Late Fee</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-maroon);"><%= number_to_currency(@statement.late_fee) %></td>
          </tr>
        <% end %>
        <tr>
          <td style="padding: 0.375rem 0; color: var(--color-steel);">Payments Received</td>
          <td class="text-money" style="padding: 0.375rem 0; font-size: inherit;">(<%= number_to_currency(@statement.payments_received) %>)</td>
        </tr>
        <% if @loan.split_payment? %>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Cash</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);"><%= number_to_currency(@loan.monthly_cash_payment) %></td>
          </tr>
          <tr>
            <td style="padding: 0.25rem 0 0.25rem 0.75rem; color: var(--color-concrete);"><span style="color: var(--color-concrete); margin-right: 0.375rem;">&#x2514;</span> Reserve</td>
            <td class="text-money" style="padding: 0.25rem 0; font-size: inherit; color: var(--color-concrete);"><%= number_to_currency(@loan.reserve_payment_amount) %></td>
          </tr>
        <% end %>
        <% if @statement.past_due_amount > 0 %>
          <tr style="border-top: 2px solid #000;">
            <td style="padding: 0.625rem 0 0; font-weight: 600; color: var(--color-maroon);">Past Due</td>
            <td class="text-money" style="padding: 0.625rem 0 0; font-weight: 600; font-size: inherit; color: var(--color-maroon);"><%= number_to_currency(@statement.past_due_amount) %></td>
          </tr>
        <% else %>
          <tr style="border-top: 2px solid #000;">
            <td style="padding: 0.625rem 0 0; font-weight: 600; color: var(--color-slate-blue-dark);">Paid in Full</td>
            <td class="text-money" style="padding: 0.625rem 0 0; font-weight: 600; font-size: inherit; color: var(--color-slate-blue-dark);"><%= number_to_currency(0) %></td>
          </tr>
        <% end %>
      </table>
    </div>
  </div>

  <%# ── Reserves ── %>
  <% active_reserves = @loan.loan_reserves.active.order(:established_date) %>
  <% if active_reserves.any? %>
    <div class="card" style="padding: 0; margin-bottom: 1.5rem;">
      <div style="padding: 1.5rem 2rem 0;">
        <h3 class="heading-3">Reserves</h3>
      </div>
      <div class="table-container" style="padding: 1rem 0 0;">
        <table class="data-table" style="min-width: 600px;">
          <thead>
            <tr>
              <th style="padding-left: 2rem;">Reserve</th>
              <th>Established</th>
              <th class="text-right">Original</th>
              <th class="text-right" style="padding-right: 2rem;">Remaining</th>
            </tr>
          </thead>
          <tbody>
            <% active_reserves.each do |reserve| %>
              <tr>
                <td style="padding-left: 2rem; font-weight: 600;"><%= reserve.display_name %></td>
                <td><%= reserve.established_date.strftime("%b %-d, %Y") %></td>
                <td class="text-money"><%= number_to_currency(reserve.amount) %></td>
                <td class="text-money" style="padding-right: 2rem;"><%= number_to_currency(reserve.remaining_balance) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# ── Loan Activity Ledger ── %>
  <%
    activity = []
    running_balance = @statement.beginning_balance

    activity << { date: @statement.period_start, item: "Previous Balance", amount: nil, balance: running_balance }

    if @statement.interest_due > 0
      running_balance += @statement.interest_due
      activity << { date: @statement.period_start, item: "Interest Due", amount: @statement.interest_due, balance: running_balance }
    end

    if @statement.principal_due > 0
      activity << { date: @statement.period_start, item: "Principal Due", amount: @statement.principal_due, balance: running_balance }
    end

    @period_draws.each do |draw|
      running_balance += draw.amount
      activity << { date: draw.draw_date, item: "Draw Funded", description: draw.description, amount: draw.amount, balance: running_balance }
    end

    @period_fees.each do |fee|
      activity << { date: fee.fee_date, item: "Fee — #{fee.fee_type.titleize}", description: fee.description, amount: fee.amount, balance: running_balance }
    end

    if @statement.late_fee > 0
      activity << { date: @statement.period_end, item: "Late Fee", amount: @statement.late_fee, balance: running_balance }
    end

    @period_payments.each do |payment|
      running_balance -= payment.principal_amount
      desc_parts = []
      desc_parts << payment.notes if payment.notes.present?
      desc_parts << "Ref: #{payment.reference_number}" if payment.reference_number.present?
      desc_parts << "From reserve" if payment.loan_reserve_id.present?

      activity << { date: payment.payment_date, item: "Payment Received", description: desc_parts.join(" · "), amount: -payment.amount, balance: running_balance }
    end

    activity = activity.sort_by.with_index { |a, i| [a[:date], i] }
  %>

  <div class="card" style="padding: 0; margin-bottom: 1.5rem;">
    <div style="padding: 1.5rem 2rem 0;">
      <h3 class="heading-3">Loan Activity</h3>
    </div>
    <div class="table-container" style="padding: 1rem 0 0;">
      <table class="data-table" style="min-width: 600px;">
        <thead>
          <tr>
            <th style="padding-left: 2rem;">Date</th>
            <th>Item</th>
            <th class="text-right">Amount</th>
            <th class="text-right" style="padding-right: 2rem;">Balance</th>
          </tr>
        </thead>
        <tbody>
          <% activity.each do |entry| %>
            <tr>
              <td style="white-space: nowrap; padding-left: 2rem;"><%= entry[:date].strftime("%b %-d, %Y") %></td>
              <td>
                <div style="font-weight: 600;"><%= entry[:item] %></div>
                <% if entry[:description].present? %>
                  <div style="font-size: 0.75rem; color: var(--color-steel); margin-top: 1px;"><%= entry[:description] %></div>
                <% end %>
              </td>
              <td class="text-money">
                <% if entry[:amount].nil? %>
                  &mdash;
                <% elsif entry[:amount] < 0 %>
                  <span style="color: var(--color-slate-blue-dark);">(<%= number_to_currency(entry[:amount].abs) %>)</span>
                <% else %>
                  <%= number_to_currency(entry[:amount]) %>
                <% end %>
              </td>
              <td class="text-money" style="padding-right: 2rem;"><%= number_to_currency(entry[:balance]) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr style="font-weight: 600;">
            <td style="padding-left: 2rem;" colspan="2">Ending Balance</td>
            <td></td>
            <td class="text-money" style="padding-right: 2rem;"><%= number_to_currency(@statement.ending_balance) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <%# ── Next Payment ── %>
  <% if @loan.status == "active" %>
    <div class="card" style="padding: 1.25rem 2rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-left: 3px solid var(--color-navy);">
      <div>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-steel); margin-bottom: 0.25rem;">Next Payment Due</div>
        <div style="font-weight: 600; font-size: 1.125rem;">
          <%= number_to_currency(@loan.monthly_payment_amount) %>
          <span style="font-weight: 400; font-size: 0.8125rem; color: var(--color-steel); margin-left: 0.375rem;">by <%= @loan.next_payment_date.strftime("%b %-d, %Y") %></span>
        </div>
        <% if @loan.split_payment? %>
          <div style="font-size: 0.8125rem; color: var(--color-steel); margin-top: 0.375rem;">
            Cash: <strong><%= number_to_currency(@loan.monthly_cash_payment) %></strong>
            <span style="margin: 0 0.25rem;">&middot;</span>
            From Reserve: <strong><%= number_to_currency(@loan.reserve_payment_amount) %></strong>
          </div>
        <% end %>
      </div>
      <% if @loan.late_fee_percent.present? && @loan.late_fee_percent > 0 && @loan.grace_period_days.present? %>
        <div style="font-size: 0.75rem; color: var(--color-steel); max-width: 22rem; text-align: right; line-height: 1.4;">
          A late fee of <%= @loan.late_fee_percent %>% will be charged if payment is not received within <%= @loan.grace_period_days %> days of the due date.
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Payment Detail ── %>
  <% if @period_payments.any? %>
    <div class="card" style="padding: 0; margin-bottom: 1.5rem;">
      <div style="padding: 1.5rem 2rem 0;">
        <h3 class="heading-3">Payment Detail</h3>
      </div>
      <div class="table-container" style="padding: 1rem 0 0;">
        <table class="data-table" style="min-width: 700px;">
          <thead>
            <tr>
              <th style="padding-left: 2rem;">Date</th>
              <th class="text-right">Amount</th>
              <th class="text-right">Interest</th>
              <th class="text-right">Principal</th>
              <th class="text-right">Late Fee</th>
              <th style="padding-left: 1.25rem;">Method</th>
              <th>Reference</th>
              <th style="padding-right: 2rem;">Notes</th>
            </tr>
          </thead>
          <tbody>
            <% @period_payments.each do |payment| %>
              <tr>
                <td style="white-space: nowrap; padding-left: 2rem;"><%= payment.payment_date.strftime("%b %-d, %Y") %></td>
                <td class="text-money"><%= number_to_currency(payment.amount) %></td>
                <td class="text-money"><%= number_to_currency(payment.interest_amount) %></td>
                <td class="text-money"><%= number_to_currency(payment.principal_amount) %></td>
                <td class="text-money"><%= number_to_currency(payment.late_fee_amount) %></td>
                <td style="padding-left: 1.25rem;"><%= payment.payment_method&.titleize %></td>
                <td><%= payment.reference_number %></td>
                <td class="text-small" style="padding-right: 2rem;">
                  <%= payment.notes %>
                  <% if payment.loan_reserve_id.present? %>
                    <span class="badge badge-neutral" style="margin-left: 0.25rem;">Reserve</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr style="font-weight: 600;">
              <td style="padding-left: 2rem;">Total</td>
              <td class="text-money"><%= number_to_currency(@period_payments.sum(:amount)) %></td>
              <td class="text-money"><%= number_to_currency(@period_payments.sum(:interest_amount)) %></td>
              <td class="text-money"><%= number_to_currency(@period_payments.sum(:principal_amount)) %></td>
              <td class="text-money"><%= number_to_currency(@period_payments.sum(:late_fee_amount)) %></td>
              <td colspan="3"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  <% end %>

  <%# ── Send History ── %>
  <% if @statement_sends.any? %>
    <div class="card" style="padding: 0; margin-bottom: 1.5rem;">
      <div style="padding: 1.5rem 2rem 0;">
        <h3 class="heading-3">Send History</h3>
      </div>
      <div class="table-container" style="padding: 1rem 0 0;">
        <table class="data-table" style="min-width: 500px;">
          <thead>
            <tr>
              <th style="padding-left: 2rem;">Date</th>
              <th>Sent To</th>
              <th>CC</th>
              <th style="padding-right: 2rem;">Sent By</th>
            </tr>
          </thead>
          <tbody>
            <% @statement_sends.each do |send_record| %>
              <tr>
                <td style="white-space: nowrap; padding-left: 2rem;"><%= send_record.created_at.strftime("%b %-d, %Y at %-I:%M %p") %></td>
                <td><%= send_record.sent_to %></td>
                <td><%= send_record.cc_to %></td>
                <td style="padding-right: 2rem;"><%= send_record.sent_by.display_name %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# ── Footer Actions ── %>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
    <%= link_to "&larr; Back to Loan".html_safe, admin_loan_path(@loan, tab: "statements"), style: "font-size: 0.8125rem; color: var(--color-steel);" %>
    <%= button_to "Delete Statement", admin_loan_loan_statement_path(@loan, @statement), method: :delete, class: "btn-filled btn-filled-danger", style: "font-size: 11px; padding: 6px 14px;", data: { turbo_confirm: "Are you sure you want to delete this statement?" } %>
  </div>

  <% unless @statement.stale? %>
    <%= render "admin/loan_statements/send_modal" %>
  <% end %>
</div>
