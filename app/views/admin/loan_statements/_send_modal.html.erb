<div class="modal-overlay" id="send-statement-modal">
  <div class="modal" style="max-width: 30rem;">
    <div class="modal-header">
      <h2 class="heading-2">Send Statement</h2>
      <button type="button" data-modal-close>&times;</button>
    </div>

    <div class="modal-body">
      <%= form_with url: send_to_client_admin_loan_loan_statement_path(@loan, @statement), method: :post do |f| %>

        <div class="field" style="margin-bottom: 1.25rem;">
          <%= f.label :sent_to, "Email statement to" %>
          <%= f.email_field :sent_to, value: @default_recipient_email, class: "field-input", required: true %>
        </div>

        <div class="field" style="margin-bottom: 1.5rem;">
          <%= f.label :cc_to, "Copy statement to" %>
          <%= f.email_field :cc_to, value: "admin@linchpinrealty.com", class: "field-input" %>
        </div>

        <p class="text-small" style="margin-bottom: 1.5rem; color: var(--color-steel);">
          The statement PDF for <%= @statement.period_start.strftime("%b %-d") %> &ndash; <%= @statement.period_end.strftime("%b %-d, %Y") %> will be attached to the email.
        </p>

        <div class="modal-actions">
          <%= btn_filled_tag "Send Statement", nil, type: "submit", variant: "primary" %>
          <a href="#" data-modal-close style="font-size: 0.8125rem; color: var(--color-steel);">Cancel</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
