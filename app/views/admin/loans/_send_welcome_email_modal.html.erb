<div class="modal-overlay" id="send-welcome-email-modal">
  <div class="modal" style="max-width: 30rem;">
    <div class="modal-header">
      <h2 class="heading-2">Send Welcome Email</h2>
      <button type="button" data-modal-close>&times;</button>
    </div>

    <div class="modal-body">
      <%= form_with url: send_welcome_email_admin_loan_path(@loan), method: :post do |f| %>

        <div class="field" style="margin-bottom: 1.25rem;">
          <%= f.label :sent_to, "Email welcome letter to" %>
          <%= f.email_field :sent_to, value: @default_recipient_email, class: "field-input", required: true %>
        </div>

        <div class="field" style="margin-bottom: 1.5rem;">
          <%= f.label :cc_to, "Copy to" %>
          <%= f.email_field :cc_to, value: "admin@linchpinrealty.com", class: "field-input" %>
        </div>

        <% if @documents.any? %>
          <div class="field" style="margin-bottom: 1.5rem;">
            <label class="field-label">Attach documents</label>
            <div style="max-height: 10rem; overflow-y: auto; border: 1px solid var(--color-border); border-radius: 0.375rem; padding: 0.5rem; box-shadow: inset 0 2px 4px rgba(0,0,0,0.08); background: rgba(0,0,0,0.02);">
              <% @documents.each do |doc| %>
                <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0; font-size: 0.8125rem; cursor: pointer;">
                  <input type="checkbox" name="document_ids[]" value="<%= doc.id %>">
                  <%= doc.name.presence || LoanDocument::DOCUMENT_TYPES[doc.document_type] || doc.document_type %>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>

        <p class="text-small" style="margin-bottom: 1.5rem; color: var(--color-steel);">
          This will send loan details and payment options (Zelle, ACH, wire, check) to the borrower, with the Payment Options PDF attached.
        </p>

        <div class="modal-actions">
          <%= btn_filled_tag "Send Welcome Email", nil, type: "submit", variant: "primary" %>
          <a href="#" data-modal-close style="font-size: 0.8125rem; color: var(--color-steel);">Cancel</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
