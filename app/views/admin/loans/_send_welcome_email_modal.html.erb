<div class="modal-overlay" id="send-welcome-email-modal">
  <div class="modal" style="max-width: 64rem; display: flex; flex-direction: column;">
    <div class="modal-header">
      <h2 class="heading-2">Send Welcome Email</h2>
      <button type="button" data-modal-close>&times;</button>
    </div>

    <div class="modal-body" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;" id="welcome-email-modal-body">
      <%# ── Left: Form ── %>
      <div>
        <%= form_with url: send_welcome_email_admin_loan_path(@loan), method: :post do |f| %>
          <div class="field" style="margin-bottom: 1.25rem;">
            <%= f.label :sent_to, "Email welcome letter to" %>
            <%= f.email_field :sent_to, value: @default_recipient_email, class: "field-input", required: true %>
          </div>

          <div class="field" style="margin-bottom: 1.25rem;">
            <%= f.label :cc_to, "Copy to" %>
            <%= f.email_field :cc_to, value: "admin@linchpinrealty.com", class: "field-input" %>
          </div>

          <div class="field" style="margin-bottom: 1.25rem;">
            <label class="field-label">Additional Message</label>
            <textarea name="custom_message" class="field-input" rows="4" placeholder="Add a personal note that will appear at the top of the email..." id="welcome-custom-message"></textarea>
            <p class="field-hint" style="margin-top: 0.25rem;">Shown below the greeting, before loan details.</p>
          </div>

          <% if @documents.any? %>
            <div class="field" style="margin-bottom: 1.5rem;">
              <label class="field-label">Attach documents</label>
              <div style="max-height: 10rem; overflow-y: auto; border: 1px solid var(--color-border); border-radius: 0.375rem; padding: 0.5rem; box-shadow: inset 0 2px 4px rgba(0,0,0,0.08); background: rgba(0,0,0,0.02);">
                <% @documents.each do |doc| %>
                  <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0; font-size: 0.8125rem; cursor: pointer;">
                    <input type="checkbox" name="document_ids[]" value="<%= doc.id %>" data-filename="<%= doc.file.attached? ? doc.file.filename : 'document' %>" data-docname="<%= doc.name.presence || LoanDocument::DOCUMENT_TYPES[doc.document_type] || doc.document_type.titleize %>">
                    <%= doc.name.presence || LoanDocument::DOCUMENT_TYPES[doc.document_type] || doc.document_type %>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="modal-actions">
            <%= btn_filled_tag "Send Welcome Email", nil, type: "submit", variant: "primary" %>
            <a href="#" data-modal-close style="font-size: 0.8125rem; color: var(--color-steel);">Cancel</a>
          </div>
        <% end %>
      </div>

      <%# ── Right: Email Preview ── %>
      <div style="border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; max-height: 32rem; overflow-y: auto; background: #fff;">
        <div style="padding: 0.5rem 0.75rem; background: var(--color-smoke); border-bottom: 1px solid #e5e7eb;">
          <span style="font-family: 'Barlow Condensed', sans-serif; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-steel);">Email Preview</span>
        </div>
        <div style="transform: scale(0.6); transform-origin: top left; width: 166.67%; pointer-events: none;">
          <div style="max-width: 600px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a2744;">
            <div style="padding: 2rem; background: #1a2744; text-align: center;">
              <h1 style="color: #ffffff; margin: 0; font-size: 1.5rem;">Linchpin Realty</h1>
            </div>

            <div style="padding: 2rem; background: #ffffff;">
              <p style="margin-top: 0;">Hi <%= @loan.borrower_name %>,</p>
              <p>Thank you for choosing Linchpin Realty. Below you'll find the details of your loan along with all available payment options.</p>

              <%# Custom message placeholder %>
              <div id="welcome-preview-message" style="display: none; padding: 1rem 1.25rem; background: #f9fafb; border-left: 3px solid #1a2744; border-radius: 0.25rem; margin: 1rem 0 1.5rem; font-size: 0.9375rem; line-height: 1.6; white-space: pre-line;"></div>

              <%# Loan Information Section %>
              <div style="margin: 1.5rem 0; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden;">
                <div style="padding: 0.5rem 1rem; background: #1a2744;">
                  <h3 style="margin: 0; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #ffffff;">Loan Information</h3>
                </div>
                <div style="padding: 1rem;">
                  <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                    <tr>
                      <td style="padding: 0.375rem 0; color: #6b7280;">Property</td>
                      <td style="padding: 0.375rem 0; text-align: right; font-weight: 600;"><%= @loan.property_address %></td>
                    </tr>
                    <tr style="border-top: 1px solid #e5e7eb;">
                      <td style="padding: 0.375rem 0; color: #6b7280;">Loan Amount</td>
                      <td style="padding: 0.375rem 0; text-align: right; font-weight: 600;"><%= number_to_currency(@loan.loan_amount) %></td>
                    </tr>
                    <tr style="border-top: 1px solid #e5e7eb;">
                      <td style="padding: 0.375rem 0; color: #6b7280;">Rate</td>
                      <td style="padding: 0.375rem 0; text-align: right; font-weight: 600;"><%= @loan.effective_interest_rate %>%</td>
                    </tr>
                    <tr style="border-top: 1px solid #e5e7eb;">
                      <td style="padding: 0.375rem 0; color: #6b7280;">Monthly Payment</td>
                      <td style="padding: 0.375rem 0; text-align: right; font-weight: 600;"><%= number_to_currency(@loan.monthly_payment_amount) %></td>
                    </tr>
                    <tr style="border-top: 1px solid #e5e7eb;">
                      <td style="padding: 0.375rem 0; color: #6b7280;">Maturity</td>
                      <td style="padding: 0.375rem 0; text-align: right; font-weight: 600;"><%= @loan.effective_maturity_date.strftime("%b %-d, %Y") %></td>
                    </tr>
                  </table>
                </div>
              </div>

              <%# Payment Options Section %>
              <div style="margin: 1.5rem 0; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden;">
                <div style="padding: 0.5rem 1rem; background: #1a2744;">
                  <h3 style="margin: 0; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #ffffff;">Payment Options</h3>
                </div>
                <div style="padding: 1rem; font-size: 0.8125rem;">
                  <p style="color: #6b7280; margin: 0 0 1rem;">Please include the borrower's name and loan number with all payments.</p>

                  <h4 style="margin: 0 0 0.25rem; font-size: 0.875rem; color: #1a2744;">Zelle</h4>
                  <p style="margin: 0 0 1rem;">Search for <strong>Linchpin Realty</strong> using anthony@linchpinrealty.com or 949-524-1246.</p>

                  <div style="border-top: 1px solid #e5e7eb; padding-top: 0.75rem;">
                    <h4 style="margin: 0 0 0.25rem; font-size: 0.875rem; color: #1a2744;">ACH Transfer</h4>
                    <p style="font-size: 0.75rem; color: #6b7280; margin: 0 0 0.375rem; font-style: italic;">Different routing number than wire.</p>
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.8125rem;">
                      <tr><td style="padding: 0.125rem 0; color: #6b7280; width: 35%;">Pay To</td><td style="padding: 0.125rem 0; font-weight: 600;">Linchpin Realty LLC</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Routing</td><td style="padding: 0.125rem 0; font-weight: 600;">322271627</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Account</td><td style="padding: 0.125rem 0; font-weight: 600;">511826676</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Bank</td><td style="padding: 0.125rem 0; font-weight: 600;">JPMorgan Chase</td></tr>
                    </table>
                  </div>

                  <div style="border-top: 1px solid #e5e7eb; margin-top: 0.75rem; padding-top: 0.75rem;">
                    <h4 style="margin: 0 0 0.25rem; font-size: 0.875rem; color: #1a2744;">Wire Transfer</h4>
                    <p style="font-size: 0.75rem; color: #6b7280; margin: 0 0 0.375rem; font-style: italic;">Different routing number than ACH.</p>
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.8125rem;">
                      <tr><td style="padding: 0.125rem 0; color: #6b7280; width: 35%;">Pay To</td><td style="padding: 0.125rem 0; font-weight: 600;">Linchpin Realty LLC</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Routing</td><td style="padding: 0.125rem 0; font-weight: 600;">122235821</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Account</td><td style="padding: 0.125rem 0; font-weight: 600;">157533834295</td></tr>
                      <tr><td style="padding: 0.125rem 0; color: #6b7280;">Bank</td><td style="padding: 0.125rem 0; font-weight: 600;">US Bank</td></tr>
                    </table>
                  </div>

                  <div style="border-top: 1px solid #e5e7eb; margin-top: 0.75rem; padding-top: 0.75rem;">
                    <h4 style="margin: 0 0 0.25rem; font-size: 0.875rem; color: #1a2744;">Pay by Check</h4>
                    <p style="margin: 0;">Mail to <strong>26895 Aliso Creek Road, B-62, Aliso Viejo, CA 92656</strong></p>
                  </div>
                </div>
              </div>

              <%# Attachments Section %>
              <div id="welcome-preview-attachments" style="margin: 1.5rem 0; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden;">
                <div style="padding: 0.5rem 1rem; background: #1a2744;">
                  <h3 style="margin: 0; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #ffffff;">Attached Documents</h3>
                </div>
                <div style="padding: 1rem;" id="welcome-preview-attachments-list"></div>
              </div>

              <%# Client Portal %>
              <div style="margin: 1.5rem 0; padding: 1rem; background: #f9fafb; border-radius: 0.5rem; border: 1px solid #e5e7eb;">
                <p style="margin: 0; font-size: 0.8125rem; line-height: 1.5; color: #6b7280;">
                  You'll receive an invitation to create an account on our client portal to view loan details, transaction history, statements, and documents.
                </p>
              </div>

              <%# Closing %>
              <p style="font-size: 0.8125rem; margin-top: 1rem;">
                Best regards,<br><strong>The Linchpin Realty Team</strong>
              </p>
            </div>

            <div style="padding: 0.75rem 1.5rem; background: #f3f4f6; text-align: center; font-size: 0.6875rem; color: #9ca3af;">
              Linchpin Realty &mdash; Private Lending Solutions
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var textarea = document.getElementById("welcome-custom-message");
    var msgPreview = document.getElementById("welcome-preview-message");
    var attSection = document.getElementById("welcome-preview-attachments");
    var attList = document.getElementById("welcome-preview-attachments-list");
    var checkboxes = document.querySelectorAll('#send-welcome-email-modal input[name="document_ids[]"]');

    if (textarea && msgPreview) {
      textarea.addEventListener("input", function() {
        if (this.value.trim()) {
          msgPreview.textContent = this.value;
          msgPreview.style.display = "block";
        } else {
          msgPreview.style.display = "none";
          msgPreview.textContent = "";
        }
      });
    }

    var fileIcon = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
    function attItem(name) {
      return '<div style="display: flex; align-items: center; gap: 0.375rem; padding: 0.25rem 0; font-size: 0.8125rem; color: #1a2744;">' + fileIcon + ' ' + name + '</div>';
    }

    function updateAttachments() {
      if (!attList) return;
      var items = [attItem("Payment Options")];
      checkboxes.forEach(function(cb) {
        if (cb.checked) items.push(attItem(cb.dataset.docname || "Document"));
      });
      attList.innerHTML = items.join("");
    }

    checkboxes.forEach(function(cb) {
      cb.addEventListener("change", updateAttachments);
    });

    updateAttachments();
  });
</script>
