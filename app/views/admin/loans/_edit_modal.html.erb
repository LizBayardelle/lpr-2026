<div class="modal-overlay" id="edit-loan-modal">
  <div class="modal modal-wide">
    <div class="modal-header">
      <div style="display: flex; align-items: center; gap: 1rem;">
        <h2 class="heading-2">Edit Loan</h2>
        <a href="#" class="btn-filled btn-filled-danger" style="font-size: 10px; padding: 4px 10px;" data-delete-loan="<%= admin_loan_path(@loan) %>">Delete Loan</a>
      </div>
      <button type="button" data-modal-close>&times;</button>
    </div>

    <div class="modal-body">
      <%= form_with model: [:admin, @loan], local: true do |f| %>
        <div data-wizard>
          <%# Step indicators %>
          <div class="wizard-steps">
            <button type="button" data-wizard-step class="wizard-step active">
              <span class="wizard-step-number">1</span>
              <span class="wizard-step-label">Borrower</span>
            </button>
            <button type="button" data-wizard-step class="wizard-step">
              <span class="wizard-step-number">2</span>
              <span class="wizard-step-label">Contact</span>
            </button>
            <button type="button" data-wizard-step class="wizard-step">
              <span class="wizard-step-number">3</span>
              <span class="wizard-step-label">Property</span>
            </button>
            <button type="button" data-wizard-step class="wizard-step">
              <span class="wizard-step-number">4</span>
              <span class="wizard-step-label">Loan Terms</span>
            </button>
            <button type="button" data-wizard-step class="wizard-step">
              <span class="wizard-step-number">5</span>
              <span class="wizard-step-label">Dates & Fees</span>
            </button>
            <button type="button" data-wizard-step class="wizard-step">
              <span class="wizard-step-number">6</span>
              <span class="wizard-step-label">Status & Notes</span>
            </button>
          </div>

          <%# ── Step 1: Borrower (Legal Entity) ── %>
          <div data-wizard-panel class="wizard-panel active">
            <p class="field-hint" style="margin-bottom: 1rem;">Legal borrower name as shown on the settlement statement.</p>
            <div class="field-row">
              <div class="field">
                <%= f.label :borrower_name, "Legal Borrower Name" %>
                <%= f.text_field :borrower_name, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :loan_number, "Loan Number" %>
                <%= f.text_field :loan_number, class: "field-input", placeholder: "e.g. LPR-2026-001" %>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <%= f.label :borrower_email, "Email" %>
                <%= f.email_field :borrower_email, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :borrower_phone, "Phone" %>
                <%= f.text_field :borrower_phone, class: "field-input" %>
              </div>
            </div>
            <div class="field">
              <%= f.label :borrower_address, "Mailing Address" %>
              <%= f.text_field :borrower_address, class: "field-input" %>
            </div>

            <div class="wizard-nav">
              <div class="wizard-nav-spacer"></div>
              <button type="button" class="btn-filled btn-filled-primary" data-wizard-nav="next">Continue</button>
            </div>
          </div>

          <%# ── Step 2: Responsible Party ── %>
          <div data-wizard-panel class="wizard-panel">
            <p class="field-hint" style="margin-bottom: 1rem;">The individual to contact about this loan. Leave blank if same as borrower.</p>
            <div class="field-row">
              <div class="field">
                <%= f.label :responsible_party_name, "Name" %>
                <%= f.text_field :responsible_party_name, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :responsible_party_email, "Email" %>
                <%= f.email_field :responsible_party_email, class: "field-input" %>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <%= f.label :responsible_party_phone, "Phone" %>
                <%= f.text_field :responsible_party_phone, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :responsible_party_address, "Mailing Address" %>
                <%= f.text_field :responsible_party_address, class: "field-input" %>
              </div>
            </div>

            <div class="wizard-nav">
              <button type="button" class="btn-filled btn-filled-ghost" data-wizard-nav="prev">Back</button>
              <button type="button" class="btn-filled btn-filled-primary" data-wizard-nav="next">Continue</button>
            </div>
          </div>

          <%# ── Step 3: Property ── %>
          <div data-wizard-panel class="wizard-panel">
            <div class="field">
              <%= f.label :property_address, "Property Address" %>
              <%= f.text_field :property_address, class: "field-input" %>
            </div>
            <div class="field-row-3">
              <div class="field">
                <%= f.label :property_type, "Type" %>
                <%= f.select :property_type, Loan::PROPERTY_TYPES.map { |k, v| [v, k] }, { include_blank: "Select..." }, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :property_subtype, "Subtype" %>
                <%= f.select :property_subtype, Loan::PROPERTY_SUBTYPES.map { |k, v| [v, k] }, { include_blank: "Select..." }, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :property_valuation, "Valuation ($)" %>
                <%= f.number_field :property_valuation, step: 0.01, class: "field-input" %>
              </div>
            </div>
            <div class="field-row-3">
              <div class="field">
                <%= f.label :property_taxes_last_paid_on, "Taxes Last Paid" %>
                <%= f.date_field :property_taxes_last_paid_on, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :property_taxes_next_due_on, "Taxes Next Due" %>
                <%= f.date_field :property_taxes_next_due_on, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :property_tax_notes, "Tax Notes" %>
                <%= f.text_field :property_tax_notes, class: "field-input" %>
              </div>
            </div>

            <div class="wizard-nav">
              <button type="button" class="btn-filled btn-filled-ghost" data-wizard-nav="prev">Back</button>
              <button type="button" class="btn-filled btn-filled-primary" data-wizard-nav="next">Continue</button>
            </div>
          </div>

          <%# ── Step 4: Loan Terms ── %>
          <div data-wizard-panel class="wizard-panel">
            <div class="field-row-3">
              <div class="field">
                <%= f.label :loan_amount, "Loan Amount" %>
                <%= f.number_field :loan_amount, step: 0.01, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :interest_rate, "Interest Rate (%)" %>
                <%= f.number_field :interest_rate, step: 0.125, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :loan_term_months, "Term (Months)" %>
                <%= f.number_field :loan_term_months, class: "field-input" %>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <%= f.label :payment_type, "Payment Type" %>
                <%= f.select :payment_type, [["Interest Only", "interest_only"], ["Fully Amortizing", "fully_amortizing"]], {}, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :interest_calc_method, "Interest Calculation" %>
                <%= f.select :interest_calc_method, [["30/360", "30_360"], ["Actual/360", "actual_360"], ["Actual/365", "actual_365"]], {}, class: "field-input" %>
              </div>
            </div>

            <div class="wizard-nav">
              <button type="button" class="btn-filled btn-filled-ghost" data-wizard-nav="prev">Back</button>
              <button type="button" class="btn-filled btn-filled-primary" data-wizard-nav="next">Continue</button>
            </div>
          </div>

          <%# ── Step 5: Dates & Fees ── %>
          <div data-wizard-panel class="wizard-panel">
            <div class="field-row-3">
              <div class="field">
                <%= f.label :origination_date, "Origination Date" %>
                <%= f.date_field :origination_date, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :maturity_date, "Maturity Date" %>
                <%= f.date_field :maturity_date, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :first_payment_date, "First Payment Date" %>
                <%= f.date_field :first_payment_date, class: "field-input" %>
              </div>
            </div>
            <div class="field-row-3">
              <div class="field">
                <label class="field-label">Origination Fee Type</label>
                <%= f.select :origination_fee_type, [
                  ["Percentage of Loan", "percent"],
                  ["Flat Dollar Amount", "flat"]
                ], {}, class: "field-input", data: { fee_type_toggle: true } %>
              </div>
              <div class="field" data-fee-field="percent" style="<%= 'display: none;' if @loan.origination_fee_type == 'flat' %>">
                <%= f.label :origination_fee_percent, "Fee (%)" %>
                <%= f.number_field :origination_fee_percent, step: 0.125, class: "field-input" %>
              </div>
              <div class="field" data-fee-field="flat" style="<%= 'display: none;' unless @loan.origination_fee_type == 'flat' %>">
                <%= f.label :origination_fee_flat, "Fee Amount ($)" %>
                <%= f.number_field :origination_fee_flat, step: 0.01, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :origination_fee_handling, "Fee Handling" %>
                <%= f.select :origination_fee_handling, [
                  ["Net Funded (withheld)", "net_funded"],
                  ["Collected Separately", "collected_separately"]
                ], {}, class: "field-input" %>
              </div>
            </div>
            <div class="field-row-3">
              <div class="field">
                <%= f.label :default_interest_rate, "Default Interest Rate (%)" %>
                <%= f.number_field :default_interest_rate, step: 0.125, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :late_fee_percent, "Late Fee (%)" %>
                <%= f.number_field :late_fee_percent, step: 0.25, class: "field-input" %>
              </div>
              <div class="field">
                <%= f.label :grace_period_days, "Grace Period (Days)" %>
                <%= f.number_field :grace_period_days, class: "field-input" %>
              </div>
            </div>

            <div class="wizard-nav">
              <button type="button" class="btn-filled btn-filled-ghost" data-wizard-nav="prev">Back</button>
              <button type="button" class="btn-filled btn-filled-primary" data-wizard-nav="next">Continue</button>
            </div>
          </div>

          <%# ── Step 6: Status & Notes ── %>
          <div data-wizard-panel class="wizard-panel">
            <div class="field">
              <%= f.label :status, "Loan Status" %>
              <%= f.select :status, [["Active", "active"], ["Paid Off", "paid_off"], ["Default", "default"], ["Foreclosure", "foreclosure"], ["Extended", "extended"]], {}, class: "field-input" %>
            </div>
            <div class="field">
              <%= f.label :notes, "Notes" %>
              <%= f.text_area :notes, class: "field-input", rows: 4 %>
            </div>

            <div class="wizard-nav">
              <button type="button" class="btn-filled btn-filled-ghost" data-wizard-nav="prev">Back</button>
              <%= btn_filled_tag "Update Loan", nil, type: "submit" %>
            </div>
          </div>
        </div>
      <% end %>

      <script>
        document.addEventListener("click", function(e) {
          var el = e.target.closest("[data-delete-loan]");
          if (!el) return;
          e.preventDefault();
          if (!confirm("Are you sure? This will delete the loan and all associated records.")) return;
          var token = document.querySelector('meta[name="csrf-token"]').content;
          fetch(el.dataset.deleteLoan, {
            method: "DELETE",
            headers: { "X-CSRF-Token": token, "Accept": "text/html" },
            redirect: "follow"
          }).then(function() { window.location = "<%= admin_loans_path %>"; });
        });
      </script>
    </div>
  </div>
</div>
