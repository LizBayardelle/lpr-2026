<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Linchpin Realty" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Linchpin Realty">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">

    <%= stylesheet_link_tag :app %>
    <%= javascript_include_tag "application", type: "module" %>
  </head>

  <body style="display: flex; flex-direction: column; min-height: 100vh;">
    <%= render "shared/navbar" unless content_for?(:hide_navbar) %>

    <% if notice.present? %>
      <div class="flash-notice"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="flash-alert"><%= alert %></div>
    <% end %>

    <main style="flex: 1;">
      <%= yield %>
    </main>

    <%= render "shared/footer" unless content_for?(:hide_footer) %>
  </body>
</html>
