<div class="container-wide" style="padding-top: 6rem;">

  <%# ──────────────────────────── HERO HEADER ──────────────────────────── %>
  <div class="card-navy dashboard-hero" style="padding: 2.5rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center;">
    <div>
      <span class="section-label" style="color: rgba(255,255,255,0.5);">Client Portal</span>
      <h1 class="heading-1" style="color: #fff; margin-top: 0.25rem;">Welcome back, <%= current_user.first_name || current_user.email %></h1>
      <% if @loans.any? %>
        <p style="color: rgba(255,255,255,0.6); margin-top: 0.5rem; font-size: 0.9375rem;">
          You have <%= pluralize(@active_loans_count, "active loan") %>.
          <% if @next_payment %>
            Next payment due <%= @next_payment.next_payment_date.strftime("%b %-d, %Y") %>.
          <% end %>
        </p>
      <% end %>
    </div>
    <div class="dashboard-hero-stats" style="display: flex; gap: 2.5rem;">
      <% if @loans.any? %>
        <div style="text-align: right;">
          <div style="color: rgba(255,255,255,0.5); font-family: 'Barlow Condensed', sans-serif; font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.15em;">Total Balance</div>
          <div style="color: #fff; font-size: 1.75rem; font-weight: 700; font-family: 'Barlow Condensed', sans-serif; margin-top: 0.125rem;"><%= number_to_currency(@total_balance) %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ──────────────────────────── QUICK ACTIONS ──────────────────────────── %>
  <div class="dashboard-actions" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1.5rem;">
    <a href="<%= upload_path %>" class="admin-action-card" style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem;">
      <div style="flex-shrink: 0; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.5rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      </div>
      <div>
        <p class="heading-4">Upload Document</p>
        <p class="text-small" style="margin-top: 0.125rem;">Send us a file securely</p>
      </div>
    </a>

    <a href="<%= edit_user_registration_path %>" class="admin-action-card" style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem;">
      <div style="flex-shrink: 0; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.5rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div>
        <p class="heading-4">My Account</p>
        <p class="text-small" style="margin-top: 0.125rem;">Update your info</p>
      </div>
    </a>

    <a href="/about#contact" class="admin-action-card" style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem;">
      <div style="flex-shrink: 0; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; background: var(--color-navy); border-radius: 0.5rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div>
        <p class="heading-4">Contact Us</p>
        <p class="text-small" style="margin-top: 0.125rem;">Questions? Get in touch</p>
      </div>
    </a>
  </div>

  <%# ──────────────────────────── YOUR LOANS ──────────────────────────── %>
  <div class="section">
    <span class="section-label" style="margin-bottom: 0;">Your Loans</span>

    <% if @loans.any? %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr)); gap: 1.25rem; margin-top: 1.5rem;">
        <% @loans.each do |loan| %>
          <a href="<%= client_loan_path(loan) %>" class="card" style="padding: 0; overflow: hidden; text-decoration: none; color: inherit; display: block;">
            <%# Card header %>
            <div style="padding: 1.5rem 1.5rem 1rem; border-bottom: 1px solid #f3f4f6;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                <div style="min-width: 0;">
                  <p class="heading-3" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= loan.property_address %></p>
                  <p class="text-small" style="color: var(--color-steel); margin-top: 0.25rem;"><%= loan.borrower_name %></p>
                </div>
                <span class="badge <%= loan.status == 'active' ? 'badge-success' : loan.status == 'paid_off' ? 'badge-navy' : 'badge-warning' %>" style="flex-shrink: 0;">
                  <%= loan.status.titleize %>
                </span>
              </div>
              <% if loan.loan_number.present? %>
                <p class="text-small" style="color: var(--color-concrete); margin-top: 0.5rem;">Loan #<%= loan.loan_number %></p>
              <% end %>
            </div>

            <%# Balance section %>
            <div style="padding: 1.25rem 1.5rem;">
              <div style="display: flex; justify-content: space-between; align-items: baseline;">
                <div class="text-small" style="color: var(--color-steel);">Current Balance</div>
                <div style="font-size: 1.25rem; font-weight: 700; font-family: 'Barlow Condensed', sans-serif; color: var(--color-navy);"><%= number_to_currency(loan.current_balance) %></div>
              </div>
              <%# Balance progress bar %>
              <% balance_pct = loan.loan_amount > 0 ? [(loan.current_balance.to_f / loan.funded_amount.to_f * 100), 100].min : 0 %>
              <div style="margin-top: 0.75rem; height: 0.375rem; background: #f3f4f6; border-radius: 1rem; overflow: hidden;">
                <div style="height: 100%; width: <%= balance_pct %>%; background: var(--color-navy); border-radius: 1rem; transition: width 0.3s ease;"></div>
              </div>
              <div style="display: flex; justify-content: space-between; margin-top: 0.375rem;">
                <span class="text-small" style="color: var(--color-concrete); font-size: 0.75rem;"><%= number_to_percentage(balance_pct, precision: 0) %> remaining</span>
                <span class="text-small" style="color: var(--color-concrete); font-size: 0.75rem;">of <%= number_to_currency(loan.funded_amount) %></span>
              </div>
            </div>

            <%# Details grid %>
            <div style="padding: 0 1.5rem 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <div style="padding: 0.75rem; background: var(--color-smoke); border-radius: 0.375rem;">
                <div class="text-small" style="color: var(--color-steel); font-size: 0.75rem;">Rate</div>
                <div style="font-weight: 600; font-size: 0.9375rem;"><%= number_to_percentage(loan.effective_interest_rate, precision: 2) %></div>
              </div>
              <div style="padding: 0.75rem; background: var(--color-smoke); border-radius: 0.375rem;">
                <div class="text-small" style="color: var(--color-steel); font-size: 0.75rem;">Monthly Payment</div>
                <div style="font-weight: 600; font-size: 0.9375rem;"><%= number_to_currency(loan.monthly_payment_amount) %></div>
              </div>
              <div style="padding: 0.75rem; background: var(--color-smoke); border-radius: 0.375rem;">
                <div class="text-small" style="color: var(--color-steel); font-size: 0.75rem;">Next Payment</div>
                <div style="font-weight: 600; font-size: 0.9375rem;"><%= loan.next_payment_date.strftime("%b %-d") %></div>
              </div>
              <div style="padding: 0.75rem; background: var(--color-smoke); border-radius: 0.375rem;">
                <div class="text-small" style="color: var(--color-steel); font-size: 0.75rem;">Maturity</div>
                <div style="font-weight: 600; font-size: 0.9375rem;"><%= loan.effective_maturity_date.strftime("%b %-d, '%y") %></div>
              </div>
            </div>

            <%# Maturity warning %>
            <% if loan.status == "active" && loan.effective_maturity_date <= 60.days.from_now.to_date %>
              <div style="padding: 0.75rem 1.5rem; background: rgba(138, 109, 43, 0.06); border-top: 1px solid rgba(138, 109, 43, 0.12);">
                <p class="text-small" style="color: var(--color-caution); font-weight: 600;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 0.25rem;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  Matures <%= loan.effective_maturity_date.strftime("%b %-d, %Y") %> &mdash; contact us about extension options
                </p>
              </div>
            <% end %>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="card" style="margin-top: 1.5rem; text-align: center; padding: 4rem 2rem;">
        <div style="width: 3rem; height: 3rem; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: var(--color-smoke); border-radius: 50%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-steel)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="10" y1="3" x2="10" y2="9"/></svg>
        </div>
        <p style="color: var(--color-soot); font-weight: 600; margin-top: 1rem;">No loans yet</p>
        <p class="text-small" style="color: var(--color-steel); margin-top: 0.5rem; max-width: 20rem; margin-left: auto; margin-right: auto;">
          If you have an active loan with Linchpin Realty, contact us and we'll link it to your account.
        </p>
        <div style="margin-top: 1.5rem;">
          <%= btn_tag "Contact Us", "/about#contact" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ──────────────────────────── STATEMENTS ──────────────────────────── %>
  <% if @statements.any? %>
    <div class="section">
      <span class="section-label" style="margin-bottom: 0;">Recent Statements</span>

      <div class="card" style="padding: 0; margin-top: 1.5rem;">
        <div class="table-container" style="padding: 1rem 0 0; overflow-x: auto; -webkit-overflow-scrolling: touch;">
          <table class="data-table">
            <thead>
              <tr>
                <th style="padding-left: 2rem;">Period</th>
                <th>Property</th>
                <th class="text-right">Balance</th>
                <th class="text-right">Total Due</th>
                <th style="padding-right: 2rem;"></th>
              </tr>
            </thead>
            <tbody>
              <% @statements.each do |statement| %>
                <tr>
                  <td style="padding-left: 2rem; white-space: nowrap; font-weight: 500;">
                    <%= statement.period_start.strftime("%b %Y") %>
                  </td>
                  <td class="text-small"><%= statement.loan.property_address %></td>
                  <td class="text-money"><%= number_to_currency(statement.ending_balance) %></td>
                  <td class="text-money"><%= number_to_currency(statement.total_due) %></td>
                  <td style="padding-right: 2rem; text-align: right;">
                    <% if statement.pdf.attached? %>
                      <%= link_to rails_blob_path(statement.pdf, disposition: "attachment"), style: "font-size: 0.8125rem; color: var(--color-navy); display: inline-flex; align-items: center; gap: 0.25rem;" do %>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        PDF
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

  <%# ──────────────────────────── YOUR UPLOADS ──────────────────────────── %>
  <div class="section">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <span class="section-label" style="margin-bottom: 0;">Your Documents</span>
      <%= btn_filled_tag "Upload New", upload_path, variant: "primary" %>
    </div>

    <% if @uploads.any? %>
      <div class="card" style="padding: 0; margin-top: 1.5rem;">
        <div class="table-container" style="padding: 1rem 0 0; overflow-x: auto; -webkit-overflow-scrolling: touch;">
          <table class="data-table">
            <thead>
              <tr>
                <th style="padding-left: 2rem;">Document</th>
                <th>Type</th>
                <th>Uploaded</th>
                <th style="padding-right: 2rem;">Status</th>
              </tr>
            </thead>
            <tbody>
              <% @uploads.each do |upload| %>
                <tr>
                  <td style="padding-left: 2rem; font-weight: 500;">
                    <% if upload.file.attached? %>
                      <%= link_to (upload.name.presence || upload.file.filename), rails_blob_path(upload.file, disposition: "inline"), target: "_blank" %>
                    <% else %>
                      <%= upload.name.presence || "Untitled" %>
                    <% end %>
                    <% if upload.description.present? %>
                      <div class="text-small" style="color: var(--color-steel); margin-top: 0.25rem;"><%= truncate(upload.description, length: 60) %></div>
                    <% end %>
                  </td>
                  <td><span class="badge badge-navy" style="white-space: nowrap;"><%= upload.document_type_label %></span></td>
                  <td class="text-small" style="white-space: nowrap;"><%= upload.created_at.strftime("%b %-d, %Y") %></td>
                  <td style="padding-right: 2rem;">
                    <% if upload.pending? %>
                      <span class="badge badge-warning">Pending Review</span>
                    <% elsif upload.assigned? %>
                      <span class="badge badge-success">Received</span>
                    <% elsif upload.rejected? %>
                      <span class="badge badge-danger">Rejected</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="card" style="margin-top: 1.5rem; text-align: center; padding: 3rem 2rem;">
        <div style="width: 3rem; height: 3rem; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: var(--color-smoke); border-radius: 50%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-steel)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <p style="color: var(--color-soot); font-weight: 600; margin-top: 1rem;">No documents uploaded</p>
        <p class="text-small" style="color: var(--color-steel); margin-top: 0.5rem;">Upload loan documents, tax returns, or other files securely.</p>
        <div style="margin-top: 1.5rem;">
          <%= btn_tag "Upload a Document", upload_path %>
        </div>
      </div>
    <% end %>
  </div>
</div>
