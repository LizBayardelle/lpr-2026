<% content_for :title, "About & Contact | Linchpin Realty" %>
<% content_for :head do %>
  <meta name="description" content="Meet the team behind Linchpin Realty and get in touch.">
<% end %>

<%# ──────────────────────────── HERO ──────────────────────────── %>
<div class="about-hero">
  <div class="about-hero-inner">
    <span class="section-label" style="color: var(--color-steel);">About Us</span>
    <h1 class="heading-display" style="color: #fff; margin-top: 0.5rem;">Built on Integrity</h1>
    <p style="max-width: 34rem; margin: 1.25rem auto 0; color: rgba(255,255,255,0.5); font-size: 1.0625rem; line-height: 1.75;">
      Real estate lending rooted in transparency, practical solutions,
      and relationships that last beyond the closing table.
    </p>
  </div>
</div>

<%# ──────────────────────────── ABOUT ──────────────────────────── %>
<div class="container-wide section">
  <div class="home-grid-2">
    <div>
      <span class="section-label">Who We Are</span>
      <p class="heading-1">Hands-On.<br>No Nonsense.<br>Results Driven.</p>
    </div>
    <div>
      <p class="text-body">
        Linchpin Realty was founded by Anthony Bayardelle, who has worked in
        real estate, investing, and client relations for over 25 years across
        several states. A born and raised New Yorker who relocated to the
        West coast, he now brings the skills he cultivated to Orange County
        and Southern California.
      </p>
      <p class="text-body" style="margin-top: 1rem;">
        Anthony is interested in all facets of real estate, from sales and
        financing to renovations and restoration of old or rundown houses.
        That hands-on experience informs every deal Linchpin Realty touches,
        keeping things practical, transparent, and focused on results.
      </p>
      <p class="text-body" style="margin-top: 1rem;">
        In his free time Anthony likes working out, mountain biking, and
        spending time with his wife, three kids, and two large, needy dogs.
      </p>
    </div>
  </div>
</div>

<%# ──────────────────────────── VALUES ──────────────────────────── %>
<div style="background: var(--color-smoke); border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">
  <div class="container-wide section">
    <span class="section-label">Our Values</span>
    <p class="heading-1" style="margin-bottom: 2.5rem;">What We Stand For</p>

    <div class="home-grid-3 loans-types-grid">
      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Transparency</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          Every deal is structured with full visibility. No hidden fees,
          no surprises, no fine print designed to confuse. You know exactly
          what you are getting into.
        </p>
      </div>

      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Integrity</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          We do what we say we will do. Our reputation is built on
          follow-through, honest communication, and treating every
          party with respect.
        </p>
      </div>

      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Excellence</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          Good enough is not the standard. From underwriting to servicing,
          we hold ourselves to a level of care that protects borrowers,
          lenders, and investors alike.
        </p>
      </div>
    </div>
  </div>
</div>

<%# ──────────────────────────── CONTACT FORM ──────────────────────────── %>
<div id="contact" class="container-wide section">
  <div class="home-grid-2">
    <div>
      <span class="section-label">Get In Touch</span>
      <p class="heading-1">Contact Us</p>
      <p class="text-body" style="margin-top: 1rem;">
        Have a question about a loan, want to discuss lending opportunities,
        or just want to say hello? Drop us a line and we will get back to
        you promptly.
      </p>

      <div style="margin-top: 2rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:anthony@linchpinrealty.com" style="font-size: 0.9375rem;">anthony@linchpinrealty.com</a>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span style="font-size: 0.9375rem; color: var(--color-soot);">Orange County, California</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <a href="https://calendly.com/anthony-socalkeys" style="font-size: 0.9375rem;">Schedule a Call</a>
        </div>
      </div>
    </div>

    <div>
      <div class="card" style="padding: 2rem;">
        <% if @errors&.any? %>
          <div style="background: rgba(107, 32, 32, 0.06); border: 1px solid rgba(107, 32, 32, 0.15); border-radius: 0.375rem; padding: 1rem; margin-bottom: 1.5rem;">
            <p style="font-weight: 600; color: var(--color-maroon); font-size: 0.875rem; margin-bottom: 0.5rem;">Please fix the following:</p>
            <ul style="list-style: disc; padding-left: 1.25rem; font-size: 0.8125rem; color: var(--color-maroon);">
              <% @errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: ContactSubmission.new, url: contact_path, method: :post do |f| %>
          <div class="field">
            <%= f.label :name, "Your Name *" %>
            <%= f.text_field :name, class: "field-input", required: true, placeholder: "Jane Smith",
                value: user_signed_in? ? current_user.display_name : params.dig(:contact_submission, :name) %>
          </div>

          <div class="field">
            <%= f.label :email, "Email Address *" %>
            <%= f.email_field :email, class: "field-input", required: true, placeholder: "jane@example.com",
                value: user_signed_in? ? current_user.email : params.dig(:contact_submission, :email) %>
          </div>

          <div class="field">
            <%= f.label :phone, "Phone Number" %>
            <%= f.phone_field :phone, class: "field-input", placeholder: "(555) 123-4567",
                value: user_signed_in? ? current_user.phone_number : params.dig(:contact_submission, :phone) %>
          </div>

          <div class="field">
            <%= f.label :subject, "Subject" %>
            <%= f.select :subject,
                options_for_select([
                  "General Inquiry",
                  "Loan Question",
                  "Lending Opportunity",
                  "Investment Inquiry",
                  "Document Follow-Up",
                  "Other"
                ], params.dig(:contact_submission, :subject)),
                { include_blank: "Select a topic..." },
                class: "field-input" %>
          </div>

          <div class="field">
            <%= f.label :message, "Message *" %>
            <%= f.text_area :message, class: "field-input", required: true,
                placeholder: "How can we help?",
                value: params.dig(:contact_submission, :message) %>
          </div>

          <%= recaptcha_v3(action: "contact", site_key: ENV.fetch("RECAPTCHA_SITE_KEY", "")) if ENV["RECAPTCHA_SITE_KEY"].present? %>

          <div class="form-actions">
            <button type="submit" class="btn" style="width: 100%; justify-content: center;">
              <span class="corners-t"></span><span class="corners-b"></span>Send Message
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# ──────────────────────────── CTA ──────────────────────────── %>
<div class="home-cta ctx-black">
  <div class="container-wide" style="padding-top: 5rem; padding-bottom: 5rem; text-align: center;">
    <div style="max-width: 36rem; margin: 0 auto;">
      <p class="heading-1" style="color: white;">Prefer to Talk?</p>
      <p style="color: var(--color-steel); margin-top: 1rem; line-height: 1.75; font-size: 0.9375rem;">
        Skip the form. Schedule a call directly and let us have a
        real conversation about what you need.
      </p>
      <div class="home-cta-buttons" style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
        <%= btn_tag "Schedule a Call", "https://calendly.com/anthony-socalkeys" %>
      </div>
    </div>
  </div>
</div>
