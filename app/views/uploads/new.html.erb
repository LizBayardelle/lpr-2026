<div class="container-narrow section" style="padding-top: 6rem;">
  <div style="max-width: 32rem; margin: 0 auto;">
    <span class="section-label">Client Document Upload</span>
    <h1 class="heading-1" style="color: var(--color-navy);">Upload a Document</h1>
    <p class="text-body" style="margin-top: 0.75rem; color: var(--color-steel);">
      Use this form to securely send documents to Linchpin Realty.
      All uploads are reviewed by our team and assigned to the appropriate file.
    </p>

    <div class="card" style="margin-top: 2rem; padding: 2rem;">
      <%= form_with model: @upload, url: upload_path, method: :post, multipart: true do |f| %>
        <% if @upload.errors.any? %>
          <div style="background: rgba(107, 32, 32, 0.06); border: 1px solid rgba(107, 32, 32, 0.15); border-radius: 0.375rem; padding: 1rem; margin-bottom: 1.5rem;">
            <p style="font-weight: 600; color: var(--color-maroon); font-size: 0.875rem; margin-bottom: 0.5rem;">
              Please fix the following:
            </p>
            <ul style="list-style: disc; padding-left: 1.25rem; font-size: 0.8125rem; color: var(--color-maroon);">
              <% @upload.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% unless user_signed_in? %>
          <div class="field">
            <%= f.label :client_name, "Your Name *" %>
            <%= f.text_field :client_name, class: "field-input", required: true, placeholder: "Jane Smith" %>
          </div>

          <div class="field">
            <%= f.label :client_email, "Email Address *" %>
            <%= f.email_field :client_email, class: "field-input", required: true, placeholder: "jane@example.com" %>
          </div>

          <div class="field">
            <%= f.label :client_phone, "Phone Number" %>
            <%= f.phone_field :client_phone, class: "field-input", placeholder: "(555) 123-4567" %>
          </div>
        <% end %>

        <div class="field">
          <%= f.label :document_type, "Document Type *" %>
          <%= f.select :document_type,
            grouped_options_for_select([
              ["Loan Documents", [
                ["Promissory Note", "promissory_note"],
                ["Deed of Trust", "deed_of_trust"],
                ["Loan Agreement", "loan_agreement"],
                ["Loan Estimate", "loan_estimate"],
                ["Closing Disclosure", "closing_disclosure"],
                ["Settlement Statement (HUD-1)", "settlement_statement"]
              ]],
              ["Property", [
                ["Appraisal", "appraisal"],
                ["Title Report", "title"],
                ["Title Insurance", "title_insurance"],
                ["Property Insurance", "property_insurance"],
                ["Inspection Report", "inspection"],
                ["Survey", "survey"],
                ["Purchase Agreement", "purchase_agreement"],
                ["Scope of Work", "scope_of_work"],
                ["Draw Request", "draw_request"]
              ]],
              ["Income & Employment", [
                ["W-2", "w2"],
                ["Tax Return", "tax_return"],
                ["Pay Stub", "pay_stub"],
                ["Profit & Loss Statement", "profit_loss"],
                ["Employment Verification", "employment_verification"],
                ["1099", "1099"]
              ]],
              ["Assets & Financials", [
                ["Bank Statement", "bank_statement"],
                ["Financial Statement", "financial_statement"],
                ["Credit Report", "credit_report"],
                ["Asset Verification", "asset_verification"]
              ]],
              ["Identity & Entity", [
                ["Photo ID", "photo_id"],
                ["Social Security Card", "social_security"],
                ["Entity Documents (LLC/Corp)", "entity_docs"],
                ["Operating Agreement", "operating_agreement"],
                ["Articles of Incorporation", "articles_of_incorporation"],
                ["Certificate of Good Standing", "certificate_of_good_standing"]
              ]],
              ["Compliance & Legal", [
                ["Borrower Authorization", "authorization"],
                ["Disclosure", "disclosure"],
                ["Legal Document", "legal"],
                ["Lien Release", "lien_release"],
                ["Subordination Agreement", "subordination_agreement"],
                ["Personal Guarantee", "guarantee"]
              ]],
              ["Other", [
                ["Correspondence", "correspondence"],
                ["Notice", "notice"],
                ["Other", "other"]
              ]]
            ], @upload.document_type),
            { include_blank: "Select a type..." },
            class: "field-input", required: true
          %>
        </div>

        <div class="field">
          <%= f.label :name, "Document Name" %>
          <%= f.text_field :name, class: "field-input", placeholder: "e.g. 2025 W-2 from Acme Corp" %>
          <p class="field-hint">Optional — a short label to help identify this document.</p>
        </div>

        <div class="field">
          <%= f.label :description, "Notes" %>
          <%= f.text_area :description, class: "field-input", placeholder: "Any additional context about this document..." %>
        </div>

        <div class="field">
          <%= f.label :file, "File *" %>
          <%= f.file_field :file, class: "field-input", required: true, style: "padding: 0.5rem;" %>
          <p class="field-hint">PDF, images, or common document formats accepted.</p>
        </div>

        <%= recaptcha_v3(action: "upload", site_key: ENV.fetch("RECAPTCHA_SITE_KEY", "")) if ENV["RECAPTCHA_SITE_KEY"].present? %>

        <div class="form-actions">
          <button type="submit" class="btn" style="width: 100%; justify-content: center;">
            <span class="corners-t"></span><span class="corners-b"></span>Upload Document
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
