<%# ──────────────────────────── HERO ──────────────────────────── %>
<div class="loans-hero">
  <div class="loans-hero-inner">
    <span class="section-label" style="color: var(--color-steel);">Hard Money Lending</span>
    <h1 class="heading-display" style="color: #fff; margin-top: 0.5rem;">Get a Loan</h1>
    <p style="max-width: 34rem; margin: 1.25rem auto 0; color: rgba(255,255,255,0.5); font-size: 1.0625rem; line-height: 1.75;">
      Competitive terms and fast, flexible solutions to finance your
      property ventures. No runaround. No red tape.
    </p>
    <div class="ctx-black" style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
      <%= btn_tag "Apply Now", "https://calendly.com/anthony-socalkeys" %>
      <%= btn_tag "Schedule a Call", "https://calendly.com/anthony-socalkeys" %>
    </div>
  </div>
</div>

<%# ──────────────────────────── WHY LINCHPIN ──────────────────────────── %>
<div class="container-wide section">
  <span class="section-label">Why Linchpin</span>

  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;" class="loans-features-grid">
    <div>
      <p class="stat-value" style="font-size: 1.5rem;">Fast Close</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        We move at the speed of your deal. Most loans fund in days, not months.
      </p>
    </div>
    <div>
      <p class="stat-value" style="font-size: 1.5rem;">Flexible Terms</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        Every deal is different. We structure loans around your project, not a checklist.
      </p>
    </div>
    <div>
      <p class="stat-value" style="font-size: 1.5rem;">Asset-Based</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        We underwrite the deal, not just the borrower. Property value drives our decisions.
      </p>
    </div>
    <div>
      <p class="stat-value" style="font-size: 1.5rem;">Transparent</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        No hidden fees, no surprises. You know exactly what you are getting into from day one.
      </p>
    </div>
  </div>
</div>

<%# ──────────────────────────── LOAN TYPES ──────────────────────────── %>
<div style="background: var(--color-smoke); border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">
  <div class="container-wide section">
    <span class="section-label">What We Finance</span>
    <p class="heading-1" style="margin-bottom: 2.5rem;">Loan Programs</p>

    <div class="home-grid-3 loans-types-grid">
      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Bridge Loans</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          Short-term financing to bridge the gap between purchase and permanent
          financing or sale. Ideal when timing matters more than anything else.
        </p>
        <ul class="loans-feature-list">
          <li>Quick approval and funding</li>
          <li>Flexible exit strategies</li>
          <li>6 to 24 month terms</li>
        </ul>
      </div>

      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Fix &amp; Flip</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          Rehab financing for investors acquiring, renovating, and reselling
          residential or commercial property. We fund the purchase and the project.
        </p>
        <ul class="loans-feature-list">
          <li>Up to 90% of purchase price</li>
          <li>100% of rehab costs available</li>
          <li>Draw schedules upon inspection</li>
        </ul>
      </div>

      <div class="card-elevated" style="padding: 2rem;">
        <p class="heading-3">Ground-Up Construction</p>
        <div class="divider" style="margin: 1rem 0;"></div>
        <p class="text-body">
          New construction financing for developers building from scratch.
          Phased draws keep your project funded from permits to certificate of occupancy.
        </p>
        <ul class="loans-feature-list">
          <li>Land and vertical construction</li>
          <li>Phased draw disbursement</li>
          <li>12 to 24 month terms</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%# ──────────────────────────── PROCESS ──────────────────────────── %>
<div class="container-wide section">
  <span class="section-label">How It Works</span>
  <p class="heading-1" style="margin-bottom: 2.5rem;">Simple Process</p>

  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;" class="loans-steps-grid">
    <div>
      <div class="loans-step-number">01</div>
      <p class="heading-3" style="margin-top: 0.75rem;">Reach Out</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        Schedule a call or submit your deal details. We will give you a
        straight answer on feasibility within 24 hours.
      </p>
    </div>
    <div>
      <div class="loans-step-number">02</div>
      <p class="heading-3" style="margin-top: 0.75rem;">Submit Your Deal</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        Provide property details, scope of work, and your exit strategy.
        We underwrite fast and keep paperwork to the essentials.
      </p>
    </div>
    <div>
      <div class="loans-step-number">03</div>
      <p class="heading-3" style="margin-top: 0.75rem;">Get Approved</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        Receive your term sheet with clear rates, fees, and timeline.
        No hidden costs, no last-minute changes.
      </p>
    </div>
    <div>
      <div class="loans-step-number">04</div>
      <p class="heading-3" style="margin-top: 0.75rem;">Close &amp; Fund</p>
      <p class="text-body" style="margin-top: 0.5rem;">
        We close through escrow and fund your deal. Most loans close
        in under a week once approved.
      </p>
    </div>
  </div>
</div>

<%# ──────────────────────────── CTA ──────────────────────────── %>
<div style="background: var(--color-navy);">
  <div class="container-wide ctx-navy" style="padding-top: 4rem; padding-bottom: 4rem; text-align: center;">
    <div style="max-width: 36rem; margin: 0 auto;">
      <p class="heading-1" style="color: white;">Have a Deal?</p>
      <p style="color: rgba(255,255,255,0.5); margin-top: 1rem; line-height: 1.75; font-size: 0.9375rem;">
        Tell us about your project. We will let you know what we can do
        and give you a term sheet within 48 hours.
      </p>
      <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
        <%= btn_tag "Schedule a Call", "https://calendly.com/anthony-socalkeys" %>
        <%= btn_tag "Email Us", "mailto:anthony@linchpinrealty.com" %>
      </div>
    </div>
  </div>
</div>

<%# ──────────────────────────── RELATED ARTICLES ──────────────────────────── %>
<% if @loan_blogs.any? %>
  <div class="container-wide section">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <div>
        <span class="section-label" style="margin-bottom: 0.5rem;">From the Knowledge Base</span>
        <p class="heading-1">Lending Insights</p>
      </div>
      <%= btn_tag "View All Articles", knowledge_index_path(category: "loans") %>
    </div>
    <div class="knowledge-grid">
      <% @loan_blogs.each do |blog| %>
        <%= render "shared/blogs/blog_card", blog: blog %>
      <% end %>
    </div>
  </div>
<% end %>

<%# ──────────────────────────── FOOTER ──────────────────────────── %>
<footer class="home-footer">
  <div class="home-footer-inner">
    <div>
      <p class="home-footer-brand">Linchpin Realty</p>
      <p class="home-footer-legal">DRE #02018158 &middot; NMLS #2643847</p>
      <p class="home-footer-legal">&copy; <%= Date.current.year %> Linchpin Realty LLC | All rights reserved.</p>
    </div>
    <div class="home-footer-links">
      <a href="#">About</a>
      <a href="/knowledge">Knowledge</a>
      <a href="#">Contact</a>
      <a href="#">Client Hub</a>
    </div>
    <div class="home-footer-links">
      <a href="mailto:anthony@linchpinrealty.com">Send Us an Email</a>
    </div>
  </div>
</footer>
