<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a2744;">
  <div style="padding: 2rem; background: #1a2744; text-align: center;">
    <h1 style="color: #ffffff; margin: 0; font-size: 1.5rem;">Linchpin Realty</h1>
  </div>

  <div style="padding: 2rem; background: #ffffff;">
    <h2 style="margin-top: 0;">Password Reset</h2>

    <p>Hi <%= @user.first_name.presence || "there" %>,</p>

    <p>An administrator has sent you a password reset link. Click the button below to set a new password:</p>

    <div style="text-align: center; margin: 2rem 0;">
      <a href="<%= @url %>" style="display: inline-block; padding: 0.75rem 2rem; background: #c9a84c; color: #fff; text-decoration: none; border-radius: 0.375rem; font-weight: 600;">
        Reset Password
      </a>
    </div>

    <p style="font-size: 0.875rem; color: #6b7280;">
      If the button doesn't work, copy and paste this link into your browser:<br>
      <a href="<%= @url %>" style="color: #c9a84c; word-break: break-all;"><%= @url %></a>
    </p>

    <p style="font-size: 0.875rem; color: #6b7280;">
      This link will expire in <%= distance_of_time_in_words(Devise.reset_password_within) %>. If you didn't request this, you can safely ignore this email.
    </p>
  </div>

  <div style="padding: 1rem 2rem; background: #f3f4f6; text-align: center; font-size: 0.75rem; color: #9ca3af;">
    Linchpin Realty &mdash; Private Lending Solutions
  </div>
</div>
